    <p class="max-w-prose text-white/70">
      Coming soon — lessons and teaching philosophy. For students who want to learn.
    </p>
    <a
      href="/"
      class="mt-4 inline-flex items-center gap-2 rounded-full border border-white/20 px-5 py-2 text-sm transition hover:bg-white hover:text-black"
    >
      <span aria-hidden="true">←</span> Back to grid
    </a>
