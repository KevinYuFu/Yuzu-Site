---
import Base from '../layouts/Base.astro';

// The four identities, each a cell in the 2x2 grid.
// `corner` places the label toward the outer corner so it never collides with
// the centered YUZU wordmark sitting over the seam.
const cells = [
  {
    href: '/software',
    num: '01',
    label: 'Software<br />Engineer',
    bg: 'bg-slate-800',
    corner: 'items-start justify-start text-left',
  },
  {
    href: '/music',
    num: '02',
    label: 'Music<br />Teacher',
    bg: 'bg-amber-800',
    corner: 'items-end justify-start text-right',
  },
  {
    href: '/rivals',
    num: '03',
    label: 'Rivals',
    bg: 'bg-red-800',
    corner: 'items-start justify-end text-left',
  },
  {
    href: '/artist',
    num: '04',
    label: 'DJ /<br />Artist',
    bg: 'bg-violet-800',
    corner: 'items-end justify-end text-right',
  },
];
---

<Base>
  <main class="group/grid relative h-screen w-screen overflow-hidden">
    <div class="grid h-full w-full grid-cols-2 grid-rows-2">
      {
        cells.map((cell) => (
          <a
            href={cell.href}
            class={`group/cell relative flex flex-col gap-2 p-8 transition-all duration-500 ease-out hover:brightness-110 group-hover/grid:opacity-40 hover:!opacity-100 md:p-14 ${cell.bg} ${cell.corner}`}
          >
            <span class="text-xs uppercase tracking-[0.3em] text-white/60 md:text-sm">
              {cell.num}
            </span>
            <h2
              class="text-2xl font-bold leading-tight text-white md:text-4xl lg:text-5xl"
              set:html={cell.label}
            />
            <span class="mt-2 inline-flex items-center gap-2 text-sm text-white/70 opacity-0 transition-opacity duration-300 group-hover/cell:opacity-100">
              Enter <span aria-hidden="true">→</span>
            </span>
          </a>
        ))
      }
    </div>

    <!-- Center wordmark. pointer-events-none so clicks pass through to the cells.
         mix-blend-difference keeps it legible over any of the four colors.
         Swap this <span> for an <img> logo later. -->
    <div class="pointer-events-none absolute inset-0 flex items-center justify-center">
      <span
        class="select-none text-5xl font-black tracking-[0.2em] text-white mix-blend-difference md:text-7xl"
      >
        YUZU
      </span>
    </div>
  </main>
</Base>
