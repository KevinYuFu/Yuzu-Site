---
import Base from '../layouts/Base.astro';
---

<Base title="DJ / Artist — Yuzu">
  <main class="flex min-h-screen flex-col items-center justify-center gap-6 bg-violet-900 p-8 text-center">
    <p class="text-sm uppercase tracking-[0.3em] text-white/50">04 — DJ / Artist</p>
    <h1 class="text-4xl font-bold md:text-6xl">DJ / Artist</h1>
    <p class="max-w-prose text-white/70">
      Coming soon — the creative side and visual centerpiece. Mixes, sets, and shows.
    </p>
    <a
      href="/"
      class="mt-4 inline-flex items-center gap-2 rounded-full border border-white/20 px-5 py-2 text-sm transition hover:bg-white hover:text-black"
    >
      <span aria-hidden="true">←</span> Back to grid
    </a>
  </main>
</Base>
